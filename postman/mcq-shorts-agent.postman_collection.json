        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  const t = j?.data?.token;",
                  "  if (t) { pm.collectionVariables.set('token', t); pm.collectionVariables.set('userId', j.data.user.id || ''); }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"secret12\"\n}",
              "options": { "raw": { "language": "json" } }
