        {
          "name": "GET /api/videos/:id/play",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  const u = j?.url;",
                  "  if (typeof u === 'string' && u.includes('token=')) {",
                  "    const q = u.split('token=')[1];",
                  "    const tok = decodeURIComponent(q.split('&')[0]);",
                  "    pm.collectionVariables.set('streamToken', tok);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
