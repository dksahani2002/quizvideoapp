{
  "name": "mcq-shorts-agent",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && echo '✅ Build complete'",
    "start": "node dist/index.js",
    "video": "tsx src/runVideoPipeline.ts",
    "upload": "tsx src/agents/uploadOrchestrator.ts",
    "clean": "rm -rf dist && echo '✅ Cleaned dist folder'",
    "smoke": "bash scripts/smoke.sh",
    "docker:lambda": "docker build --platform linux/amd64 -f Dockerfile.lambda -t mcq-shorts-agent:latest ."
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1017.0",
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "@codegenie/serverless-express": "^4.17.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^170.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "main": "index.js",
